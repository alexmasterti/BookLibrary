@page "/authors"
@inject IAuthorService AuthorService
@inject NavigationManager Nav

<PageTitle>Authors — BookShelf</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title gradient-text">Authors</h1>
        <p style="color:var(--text-muted);font-size:13px;margin:0">
            @(authors?.Count.ToString() ?? "—") authors total
        </p>
    </div>
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/authors/new")'>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add Author
    </button>
</div>

<div class="filter-bar">
    <input class="form-control" style="flex:1;min-width:180px"
           placeholder="Search by name or nationality..."
           value="@searchQuery" @oninput="OnSearchInput" />
    <button class="btn btn-secondary" @onclick="ClearFilters">Clear</button>
</div>

@if (authors is null)
{
    <div class="empty-state">
        <div class="empty-icon">⏳</div>
        <p>Loading authors...</p>
    </div>
}
else if (!filtered.Any())
{
    <div class="empty-state">
        <div class="empty-icon">📭</div>
        <p style="font-weight:600;font-size:16px;color:var(--text)">No authors found</p>
        <p>@(string.IsNullOrEmpty(searchQuery)
            ? "No authors yet. Add your first one!"
            : "No authors match your search.")</p>
        @if (!string.IsNullOrEmpty(searchQuery))
        {
            <button class="btn btn-secondary" @onclick="ClearFilters">Clear filters</button>
        }
        else
        {
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/authors/new")'>Add your first author</button>
        }
    </div>
}
else
{
    <div class="books-grid">
        @foreach (var author in filtered)
        {
            <div class="book-card">
                <div class="book-card-top">
                    <span class="book-icon">✍️</span>
                    @if (!string.IsNullOrEmpty(author.Nationality))
                    {
                        <span class="badge badge-want">@author.Nationality</span>
                    }
                </div>

                <h3 class="book-title">@author.Name</h3>

                @if (author.BirthYear.HasValue)
                {
                    <p class="book-author">b. @author.BirthYear</p>
                }

                @if (!string.IsNullOrEmpty(author.Bio))
                {
                    <p style="font-size:12px;color:var(--text-muted);margin:0.5rem 0 0;
                              display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">
                        @author.Bio
                    </p>
                }

                <div class="book-card-footer" style="margin-top:auto;padding-top:0.75rem">
                    <span style="font-size:11px;color:var(--text-dim)">
                        @author.CreatedAt.ToString("MMM yyyy")
                    </span>
                    <div class="book-card-actions">
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick='() => Nav.NavigateTo($"/authors/edit/{author.Id}")'>Edit</button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => AskDeleteConfirm(author.Id, author.Name)">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<ConfirmDialog IsVisible="showConfirm"
               Title="Delete author?"
               Message="@($"\"{pendingDeleteName}\" will be permanently removed.")"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

<Toast IsVisible="showToast" Message="@toastMessage" Type="@toastType" />

@code {
    private List<BookLibrary.Models.Author>? authors;
    private string searchQuery = string.Empty;

    private bool showConfirm = false;
    private int pendingDeleteId;
    private string pendingDeleteName = string.Empty;

    private bool showToast = false;
    private string toastMessage = string.Empty;
    private string toastType = "success";

    private IEnumerable<BookLibrary.Models.Author> filtered =>
        authors?.Where(a =>
            string.IsNullOrEmpty(searchQuery) ||
            a.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
            (a.Nationality?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)
        ) ?? Enumerable.Empty<BookLibrary.Models.Author>();

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["toast"] is string t)
        {
            toastMessage = t;
            toastType = "success";
            _ = ShowToastThenHide();
        }

        await LoadAuthors();
    }

    private async Task LoadAuthors()
        => authors = await AuthorService.GetAllAuthorsAsync();

    private void OnSearchInput(ChangeEventArgs e)
        => searchQuery = e.Value?.ToString() ?? string.Empty;

    private void ClearFilters()
        => searchQuery = string.Empty;

    private void AskDeleteConfirm(int id, string name)
    {
        pendingDeleteId   = id;
        pendingDeleteName = name;
        showConfirm       = true;
    }

    private async Task ConfirmDelete()
    {
        showConfirm = false;
        await AuthorService.DeleteAuthorAsync(pendingDeleteId);
        await LoadAuthors();
        toastMessage = $"\"{pendingDeleteName}\" deleted successfully";
        toastType    = "success";
        _ = ShowToastThenHide();
    }

    private void CancelDelete() => showConfirm = false;

    private async Task ShowToastThenHide()
    {
        showToast = true;
        StateHasChanged();
        await Task.Delay(2800);
        showToast = false;
        StateHasChanged();
    }
}

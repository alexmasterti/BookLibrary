@page "/genres"
@inject IGenreService GenreService
@inject NavigationManager Nav

<PageTitle>Genres — BookShelf</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title gradient-text">Genres</h1>
        <p style="color:var(--text-muted);font-size:13px;margin:0">
            @(genres?.Count.ToString() ?? "—") genres total
        </p>
    </div>
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/genres/new")'>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add Genre
    </button>
</div>

<div class="filter-bar">
    <input class="form-control" style="flex:1;min-width:180px"
           placeholder="Search by name..."
           value="@searchQuery" @oninput="OnSearchInput" />
    <button class="btn btn-secondary" @onclick="ClearFilters">Clear</button>
</div>

@if (genres is null)
{
    <div class="empty-state">
        <div class="empty-icon">⏳</div>
        <p>Loading genres...</p>
    </div>
}
else if (!filtered.Any())
{
    <div class="empty-state">
        <div class="empty-icon">📭</div>
        <p style="font-weight:600;font-size:16px;color:var(--text)">No genres found</p>
        <p>@(string.IsNullOrEmpty(searchQuery)
            ? "No genres yet. Add your first one!"
            : "No genres match your search.")</p>
        @if (!string.IsNullOrEmpty(searchQuery))
        {
            <button class="btn btn-secondary" @onclick="ClearFilters">Clear filters</button>
        }
        else
        {
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/genres/new")'>Add your first genre</button>
        }
    </div>
}
else
{
    <div class="books-grid">
        @foreach (var genre in filtered)
        {
            <div class="book-card">
                <div class="book-card-top">
                    <span class="book-icon">🏷️</span>
                </div>

                <h3 class="book-title">@genre.Name</h3>

                @if (!string.IsNullOrEmpty(genre.Description))
                {
                    <p style="font-size:12px;color:var(--text-muted);margin:0.5rem 0 0;
                              display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">
                        @genre.Description
                    </p>
                }

                <div class="book-card-footer" style="margin-top:auto;padding-top:0.75rem">
                    <span style="font-size:11px;color:var(--text-dim)">
                        @genre.CreatedAt.ToString("MMM yyyy")
                    </span>
                    <div class="book-card-actions">
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick='() => Nav.NavigateTo($"/genres/edit/{genre.Id}")'>Edit</button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => AskDeleteConfirm(genre.Id, genre.Name)">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<ConfirmDialog IsVisible="showConfirm"
               Title="Delete genre?"
               Message="@($"\"{pendingDeleteName}\" will be permanently removed.")"
               OnConfirm="ConfirmDelete"
               OnCancel="CancelDelete" />

<Toast IsVisible="showToast" Message="@toastMessage" Type="@toastType" />

@code {
    private List<BookLibrary.Models.Genre>? genres;
    private string searchQuery = string.Empty;

    private bool showConfirm = false;
    private int pendingDeleteId;
    private string pendingDeleteName = string.Empty;

    private bool showToast = false;
    private string toastMessage = string.Empty;
    private string toastType = "success";

    private IEnumerable<BookLibrary.Models.Genre> filtered =>
        genres?.Where(g =>
            string.IsNullOrEmpty(searchQuery) ||
            g.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
        ) ?? Enumerable.Empty<BookLibrary.Models.Genre>();

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["toast"] is string t)
        {
            toastMessage = t;
            toastType = "success";
            _ = ShowToastThenHide();
        }

        await LoadGenres();
    }

    private async Task LoadGenres()
        => genres = await GenreService.GetAllGenresAsync();

    private void OnSearchInput(ChangeEventArgs e)
        => searchQuery = e.Value?.ToString() ?? string.Empty;

    private void ClearFilters()
        => searchQuery = string.Empty;

    private void AskDeleteConfirm(int id, string name)
    {
        pendingDeleteId   = id;
        pendingDeleteName = name;
        showConfirm       = true;
    }

    private async Task ConfirmDelete()
    {
        showConfirm = false;
        await GenreService.DeleteGenreAsync(pendingDeleteId);
        await LoadGenres();
        toastMessage = $"\"{pendingDeleteName}\" deleted successfully";
        toastType    = "success";
        _ = ShowToastThenHide();
    }

    private void CancelDelete() => showConfirm = false;

    private async Task ShowToastThenHide()
    {
        showToast = true;
        StateHasChanged();
        await Task.Delay(2800);
        showToast = false;
        StateHasChanged();
    }
}

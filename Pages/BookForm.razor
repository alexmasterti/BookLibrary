@page "/books/new"
@page "/books/edit/{Id:int}"
@inject IBookService BookService
@inject IBookFactory BookFactory
@inject NavigationManager Nav

<PageTitle>@(Id is null ? "Add Book" : "Edit Book") — BookShelf</PageTitle>

<div style="max-width:520px">
    <button class="btn btn-secondary mb-4" style="gap:6px" @onclick='() => Nav.NavigateTo("/books")'>
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Back to Library
    </button>

    <div class="form-card">
        <h3>@(Id is null ? "Add New Book" : "Edit Book")</h3>

        <div class="mb-3">
            <label class="form-label">Title <span style="color:#F87171">*</span></label>
            <input class="form-control" placeholder="e.g. Clean Code" @bind="book.Title" />
        </div>

        <div class="mb-3">
            <label class="form-label">Author <span style="color:#F87171">*</span></label>
            <input class="form-control" placeholder="e.g. Robert C. Martin" @bind="book.Author" />
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem">
            <div class="mb-3">
                <label class="form-label">Genre</label>
                <input class="form-control" placeholder="e.g. Programming" @bind="book.Genre" />
            </div>
            <div class="mb-3">
                <label class="form-label">Year</label>
                <input type="number" class="form-control" placeholder="e.g. 2008" @bind="book.Year" />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">Reading Status</label>
            <select class="form-select" @bind="book.Status">
                @foreach (var status in Enum.GetValues<BookLibrary.Models.ReadingStatus>())
                {
                    <option value="@status">@StatusLabel(status)</option>
                }
            </select>
        </div>

        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert-danger mb-3">@error</div>
        }

        <div style="display:flex;gap:0.75rem">
            <button class="btn btn-primary" @onclick="Save" style="flex:1">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                    <polyline points="17 21 17 13 7 13 7 21"/>
                    <polyline points="7 3 7 8 15 8"/>
                </svg>
                @(Id is null ? "Save Book" : "Update Book")
            </button>
            <button class="btn btn-secondary" @onclick='() => Nav.NavigateTo("/books")'>
                Cancel
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private BookLibrary.Models.Book book = new();
    private string error = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        if (Id is not null)
        {
            var existing = await BookService.GetBookByIdAsync(Id.Value);
            if (existing is not null) book = existing;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(book.Title) || string.IsNullOrWhiteSpace(book.Author))
        {
            error = "Title and Author are required.";
            return;
        }

        string toastMsg;

        if (Id is null)
        {
            var newBook = BookFactory.Create(
                title: book.Title,
                author: book.Author,
                genre: book.Genre,
                year: book.Year,
                status: book.Status
            );
            await BookService.AddBookAsync(newBook);
            toastMsg = $"\"{book.Title}\" added to your library";
        }
        else
        {
            await BookService.UpdateBookAsync(book);
            toastMsg = $"\"{book.Title}\" updated successfully";
        }

        // Navigate back and carry the success message so Books.razor shows a toast
        Nav.NavigateTo($"/books?toast={Uri.EscapeDataString(toastMsg)}");
    }

    private string StatusLabel(BookLibrary.Models.ReadingStatus status) => status switch
    {
        BookLibrary.Models.ReadingStatus.Read             => "Finished",
        BookLibrary.Models.ReadingStatus.CurrentlyReading => "Currently Reading",
        _                                                  => "Want to Read"
    };
}
